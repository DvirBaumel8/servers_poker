{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2022",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "noEmitOnError": false,
    "lib": ["es2022", "esnext.asynciterable"]
  },
  "include": [
    "src/**/*.ts",
    "*.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "docs",
    "public",
    "**/*.spec.ts",
    "bots"
  ]
}
