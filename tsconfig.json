{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2020",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "allowJs": true,
    "lib": ["es2020", "esnext.asynciterable"]
  },
  "exclude": [
    "node_modules",
    "dist",
    "docs",
    "public",
    "**/*.spec.ts",
    "bots"
  ]
}
