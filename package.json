{
  "name": "poker-engine",
  "version": "1.0.0",
  "description": "No-limit Texas Hold'em game server with bot API",
  "main": "dist/main.js",
  "scripts": {
    "prestart": "npm run build",
    "start": "node dist/main.js",
    "start:prod": "NODE_ENV=production node dist/main.js",
    "dev": "nest start --watch",
    "dev:debug": "nest start --watch --debug",
    "build": "nest build",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:e2e": "vitest run tests/e2e",
    "simulate": "node dist/simulation/runner.js",
    "typecheck": "tsc --noEmit",
    "migration:run": "npm run build && node dist/migrations/run.js",
    "migration:generate": "npm run build && npx typeorm migration:generate -d dist/config/typeorm.config.js",
    "migration:revert": "npm run build && npx typeorm migration:revert -d dist/config/typeorm.config.js",
    "migration:show": "npm run build && npx typeorm migration:show -d dist/config/typeorm.config.js",
    "db:drop": "npm run build && npx typeorm schema:drop -d dist/config/typeorm.config.js"
  },
  "keywords": [
    "poker",
    "texas-holdem",
    "bot",
    "game-engine"
  ],
  "license": "MIT",
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/platform-socket.io": "^11.1.17",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.17",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.3.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3",
    "ts-loader": "^9.5.4",
    "typeorm": "^0.3.28",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/eslint-scope": "^8.4.0",
    "@types/estree": "^1.0.8",
    "@types/express": "^4.17.21",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^20.11.17",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.3.3",
    "vitest": "^4.1.0"
  }
}
