{
  "name": "poker-engine",
  "version": "1.0.0",
  "description": "No-limit Texas Hold'em game server with bot API",
  "main": "dist/main.js",
  "scripts": {
    "prestart": "npm run build",
    "start": "node dist/main.js",
    "start:prod": "NODE_ENV=production node dist/main.js",
    "dev": "nest start --watch",
    "dev:debug": "nest start --watch --debug",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:frontend\"",
    "build": "nest build",
    "build:frontend": "cd frontend && npm run build",
    "build:all": "npm run build && npm run build:frontend",
    "lint": "eslint \"src/**/*.ts\" \"tests/**/*.ts\" --fix",
    "test": "vitest run --exclude 'tests/e2e/**'",
    "test:watch": "vitest --exclude 'tests/e2e/**'",
    "test:cov": "vitest run --coverage --exclude 'tests/e2e/**'",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:e2e:docker": "docker compose -f docker-compose.test.yml up --abort-on-container-exit --exit-code-from test",
    "test:all": "vitest run",
    "simulate": "node dist/simulation/runner.js",
    "sim:basic": "npx ts-node tests/qa/simulations/basic.simulation.ts",
    "sim:single": "npx ts-node tests/qa/simulations/single-table.simulation.ts",
    "sim:multi": "npx ts-node tests/qa/simulations/multi-table.simulation.ts",
    "sim:all": "npx ts-node tests/qa/simulations/run-all.ts --all",
    "sim:ci": "npx ts-node tests/qa/simulations/run-all.ts --basic --ci",
    "test:visual": "npx ts-node tests/qa/visual/run-visual-tests.ts",
    "test:visual:all": "npx ts-node tests/qa/visual/run-visual-tests.ts all",
    "test:load": "npx ts-node tests/qa/performance/load-test.ts api",
    "test:load:ws": "npx ts-node tests/qa/performance/load-test.ts ws",
    "test:load:games": "npx ts-node tests/qa/performance/load-test.ts games",
    "test:resilience": "npx ts-node tests/qa/performance/network-resilience.test.ts",
    "qa:monster:all": "npx ts-node tests/qa/monster/run-complete.ts all",
    "qa:monster": "npx ts-node tests/qa/monster/run-complete.ts all",
    "qa:monster:quick": "npx ts-node tests/qa/monster/generate-instructions.ts quick",
    "qa:monster:backend": "npx ts-node tests/qa/monster/run-complete.ts backend",
    "qa:monster:visual": "npx ts-node tests/qa/monster/run-complete.ts visual",
    "qa:monster:flows": "npx ts-node tests/qa/monster/run-complete.ts flows",
    "qa:monster:live": "npx ts-node tests/qa/monster/run-complete.ts live",
    "qa:monster:security": "npx ts-node tests/qa/monster/run-complete.ts security",
    "qa:monster:a11y": "npx ts-node tests/qa/monster/run-complete.ts a11y",
    "qa:monster:perf": "npx ts-node tests/qa/monster/run-complete.ts performance",
    "qa:monster:sim": "npx ts-node tests/qa-monster/robust-simulation.ts",
    "qa:monster:live-tournament": "npx ts-node tests/qa-monster/live-tournament-test.ts",
    "qa:inventory": "npx ts-node tests/qa/monster/complete-inventory.ts",
    "qa:coverage": "npx ts-node tests/qa/monster/check-coverage.ts --all",
    "qa:coverage:check": "npx ts-node tests/qa/monster/check-coverage.ts",
    "qa:quick": "npx ts-node tests/qa/visual/run-monster.ts quick",
    "qa:responsive": "npx ts-node tests/qa/visual/run-monster.ts responsive",
    "qa:states": "npx ts-node tests/qa/visual/run-monster.ts states",
    "qa:overlaps": "npx ts-node tests/qa/visual/run-monster.ts overlaps",
    "qa:flows": "npx ts-node tests/qa/visual/run-monster.ts flows",
    "qa:errors": "npx ts-node tests/qa/visual/run-monster.ts errors",
    "typecheck": "tsc --noEmit",
    "security:audit": "npm audit --audit-level=high && cd frontend && npm audit --audit-level=high",
    "security:audit:fix": "npm audit fix && cd frontend && npm audit fix",
    "preinstall": "npm audit --audit-level=critical || true",
    "license:check": "license-checker --onlyAllow 'MIT;Apache-2.0;BSD-2-Clause;BSD-3-Clause;ISC;0BSD;CC0-1.0;CC-BY-4.0;CC-BY-3.0;Unlicense;Python-2.0;BlueOak-1.0.0;MPL-2.0' --excludePrivatePackages",
    "prepare": "husky",
    "migration:run": "npm run build && node dist/src/migrations/run.js",
    "migration:generate": "npm run build && npx typeorm migration:generate -d dist/src/config/typeorm.config.js",
    "migration:revert": "npm run build && npx typeorm migration:revert -d dist/src/config/typeorm.config.js",
    "migration:show": "npm run build && npx typeorm migration:show -d dist/src/config/typeorm.config.js",
    "db:drop": "npm run build && npx typeorm schema:drop -d dist/src/config/typeorm.config.js"
  },
  "keywords": [
    "poker",
    "texas-holdem",
    "bot",
    "game-engine"
  ],
  "license": "MIT",
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "tests/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.17",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.17",
    "@nestjs/platform-socket.io": "^11.1.17",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.0",
    "@nestjs/websockets": "^11.1.17",
    "@types/nodemailer": "^7.0.11",
    "bcrypt": "^6.0.0",
    "class-sanitizer": "^1.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.3.1",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "nodemailer": "^8.0.3",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "sanitize-html": "^2.17.2",
    "socket.io": "^4.8.3",
    "ts-loader": "^9.5.4",
    "typeorm": "^0.3.28",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/testing": "^11.1.17",
    "@types/bcrypt": "^6.0.0",
    "@types/estree": "^1.0.8",
    "@types/ioredis": "^4.28.10",
    "@types/json-schema": "^7.0.15",
    "@types/node": "^25.5.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitest/coverage-v8": "^4.1.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.1.7",
    "license-checker": "^25.0.1",
    "lint-staged": "^16.4.0",
    "node-fetch": "^2.7.0",
    "prettier": "^3.3.3",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2",
    "typescript-eslint": "^8.57.1",
    "vitest": "^4.1.0",
    "ws": "^8.17.0"
  }
}
