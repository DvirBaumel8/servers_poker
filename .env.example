# ============================================
# Poker Tournament Server - Environment Config
# ============================================

# Server Configuration
PORT=3000
NODE_ENV=production

# Database
# Path to SQLite database file
DB_PATH=./data/poker.db

# Logging
LOG_DIR=./logs
LOG_LEVEL=info

# Reverse Proxy
# Set to 1 if behind a reverse proxy (nginx, Caddy, etc.)
# This enables trusting X-Forwarded-For headers for rate limiting
TRUST_PROXY=0

# ============================================
# Cloud Provider Specific (uncomment as needed)
# ============================================

# AWS
# AWS_REGION=us-east-1

# GCP
# GOOGLE_CLOUD_PROJECT=your-project-id

# Azure
# AZURE_SUBSCRIPTION_ID=your-subscription-id
