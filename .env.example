# ============================================
# Poker Tournament Server - Environment Config
# ============================================

# Server Configuration
PORT=3000
NODE_ENV=development
APP_NAME=Poker Tournament Platform
REQUEST_TIMEOUT_MS=30000

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=poker
DB_SSL=false
DB_POOL_SIZE=20

# JWT Authentication
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=24h

# Security
CORS_ORIGINS=http://localhost:3001,http://localhost:3000

# Rate Limiting
# Global default: 300 requests per minute (5 req/sec) per IP
# This is generous for power users with multiple tabs
# Sensitive endpoints (auth) have stricter per-route limits
RATE_LIMIT_MAX=300
RATE_LIMIT_WINDOW_MS=60000

# Rate Limit Bypass (for load testing and internal services)
# Skip rate limiting for localhost (default: true in dev, false in prod)
RATE_LIMIT_SKIP_LOCALHOST=true
# Secret key for X-Load-Test-Key header bypass (set for external load testing)
# Generate with: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# LOAD_TEST_KEY=your-secret-load-test-key

# API Key Security
# HMAC secret for hashing API keys - MUST be set in production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY_HMAC_SECRET=change-me-in-production-generate-random-32-bytes
API_KEY_GRACE_PERIOD_MS=86400000

# Bot Configuration
BOT_TIMEOUT_MS=10000
BOT_MAX_RETRIES=1
BOT_RETRY_DELAY_MS=500
BOT_CIRCUIT_BREAKER_THRESHOLD=5
BOT_CIRCUIT_BREAKER_RESET_MS=30000
BOT_HEALTH_CHECK_ENABLED=true
BOT_HEALTH_CHECK_INTERVAL_MS=30000
BOT_ACTIVE_GAME_CHECK_INTERVAL_MS=10000
BOT_FALLBACK_STRATEGY=conservative
BOT_RECOVERY_TIMEOUT_MS=5000
MAX_BODY_SIZE=65536

# Redis PubSub Configuration
REDIS_PUBSUB_POLL_MS=100

# Logging
LOG_DIR=./logs
LOG_LEVEL=info

# Game State Persistence & Recovery
GAME_STATE_PERSISTENCE=true
GAME_STATE_PERSIST_INTERVAL_MS=5000
GAME_STATE_CLEANUP_INTERVAL_MS=3600000
GAME_STATE_RECOVERY_WINDOW_MINUTES=30
GAME_AUTO_RECOVER=true
GAME_RECOVERY_DELAY_MS=5000

# Worker Threads (Game Isolation)
# When enabled, each game runs in a separate worker thread for fault isolation
ENABLE_WORKER_THREADS=false
MAX_CONCURRENT_GAMES=100
WORKER_TIMEOUT=30000

# Redis (State Synchronization for Horizontal Scaling)
# When Redis is configured, game state is synchronized across instances
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=poker:

# Instance Configuration (for multi-instance deployments)
# Each instance should have a unique ID; defaults to auto-generated UUID
# INSTANCE_ID=instance-1
GAME_OWNERSHIP_TTL_MS=10000
GAME_OWNERSHIP_RENEWAL_MS=3000

# Tournament Scheduler
# Automatically starts scheduled tournaments when their start time is reached
TOURNAMENT_SCHEDULER_ENABLED=true
# How often to check for scheduled tournaments (cron expression)
# Default: every 30 seconds = "*/30 * * * * *"
# Every minute = "0 * * * * *"
# Every 5 minutes = "0 */5 * * * *"
TOURNAMENT_SCHEDULER_CRON=*/30 * * * * *

# Tournament Scheduler Interval (in milliseconds)
# How often to check for scheduled tournaments
TOURNAMENT_SCHEDULER_INTERVAL_MS=30000

# Daily Summary Email
DAILY_SUMMARY_ENABLED=false
DAILY_SUMMARY_RECIPIENTS=admin@yourcompany.com
DAILY_SUMMARY_HOUR=8

# ============================================
# Monitoring & Observability
# ============================================

# Sentry Error Tracking
# Get your DSN from https://sentry.io
# SENTRY_DSN=https://your-key@sentry.io/your-project

# Prometheus metrics are exposed at /api/v1/metrics endpoint
# No configuration needed - enabled by default

# Prometheus Server (docker-compose monitoring profile)
PROMETHEUS_PORT=9090

# Grafana Dashboard
GRAFANA_PORT=3002
GRAFANA_ADMIN_PASSWORD=change-me-in-production
GRAFANA_ROOT_URL=http://localhost:3002

# Alertmanager (Email Alerts)
ALERTMANAGER_PORT=9093

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=alerts@yourcompany.com
SMTP_PASS=your-app-password
EMAIL_FROM=noreply@poker-platform.com

# ============================================
# Production Database (Managed PostgreSQL)
# ============================================
# DB_HOST=your-db-host.region.rds.amazonaws.com
# DB_PORT=5432
# DB_USERNAME=poker_app
# DB_PASSWORD=your-secure-password
# DB_NAME=poker_production
# DB_SSL=true
# DB_POOL_SIZE=50
