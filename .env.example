# ============================================
# Poker Tournament Server - Environment Config
# ============================================

# Server Configuration
PORT=3000
NODE_ENV=development

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=poker
DB_SSL=false
DB_POOL_SIZE=20

# JWT Authentication
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRES_IN=24h

# Security
CORS_ORIGINS=http://localhost:3001,http://localhost:3000
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000

# API Key Security
# HMAC secret for hashing API keys - MUST be set in production
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
API_KEY_HMAC_SECRET=change-me-in-production-generate-random-32-bytes
API_KEY_GRACE_PERIOD_MS=86400000

# Bot Configuration
BOT_TIMEOUT_MS=10000
BOT_MAX_RETRIES=1
BOT_RETRY_DELAY_MS=500
BOT_CIRCUIT_BREAKER_THRESHOLD=5
BOT_CIRCUIT_BREAKER_RESET_MS=30000
BOT_HEALTH_CHECK_ENABLED=true
BOT_HEALTH_CHECK_INTERVAL_MS=30000
BOT_ACTIVE_GAME_CHECK_INTERVAL_MS=10000
BOT_FALLBACK_STRATEGY=conservative
MAX_BODY_SIZE=65536

# Logging
LOG_DIR=./logs
LOG_LEVEL=info

# Game State Persistence & Recovery
GAME_STATE_PERSISTENCE=true
GAME_STATE_PERSIST_INTERVAL_MS=5000
GAME_STATE_CLEANUP_INTERVAL_MS=3600000
GAME_STATE_RECOVERY_WINDOW_MINUTES=30
GAME_AUTO_RECOVER=true
GAME_RECOVERY_DELAY_MS=5000

# Worker Threads (Game Isolation)
# When enabled, each game runs in a separate worker thread for fault isolation
ENABLE_WORKER_THREADS=false
MAX_CONCURRENT_GAMES=100
WORKER_TIMEOUT=30000

# Redis (State Synchronization for Horizontal Scaling)
# When Redis is configured, game state is synchronized across instances
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=poker:

# Instance Configuration (for multi-instance deployments)
# Each instance should have a unique ID; defaults to auto-generated UUID
# INSTANCE_ID=instance-1
GAME_OWNERSHIP_TTL_MS=10000
GAME_OWNERSHIP_RENEWAL_MS=3000

# Reverse Proxy
# Set to 1 if behind a reverse proxy (nginx, Caddy, etc.)
TRUST_PROXY=0

# Daily Summary Email
DAILY_SUMMARY_ENABLED=false
DAILY_SUMMARY_RECIPIENTS=admin@yourcompany.com
DAILY_SUMMARY_HOUR=8
DAILY_SUMMARY_TIMEZONE=UTC

# Analytics
ANALYTICS_RETENTION_DAYS=90

# ============================================
# Production Database (Managed PostgreSQL)
# ============================================
# DB_HOST=your-db-host.region.rds.amazonaws.com
# DB_PORT=5432
# DB_USERNAME=poker_app
# DB_PASSWORD=your-secure-password
# DB_NAME=poker_production
# DB_SSL=true
# DB_POOL_SIZE=50
